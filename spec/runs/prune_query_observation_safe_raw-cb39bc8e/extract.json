  "signature": "pub fn prune_query_observation_safe_raw(\n    block_number: u64,\n    pruned_through: u64,\n    retained: u64,\n    returned_ok: u64,\n    returned_pruned: u64,\n) -> bool",
  "body": "{\n    retained <= 1\n        && returned_ok <= 1\n        && returned_pruned <= 1\n        && ((block_number <= pruned_through\n            && retained == 0\n            && returned_ok == 0\n            && returned_pruned == 1)\n            || (pruned_through < block_number && returned_pruned == 0 && retained == returned_ok))\n}",
