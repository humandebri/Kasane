  },
  "signature": "pub fn get_queue_snapshot(limit: usize, cursor: Option<u64>) -> QueueSnapshot",
  "body": "{\n    with_state(|state| {\n        let mut items = Vec::new();\n        let mut next_cursor = None;\n        let mut last_seq = None;\n        let start_seq = cursor.unwrap_or(0);\n        let start_key = ReadySeqKey::new(start_seq, [0u8; 32]);\n        for entry in state.ready_by_seq.range(start_key..) {\n            if verified_core::batch::snapshot_limit_reached(items.len(), limit) {\n                next_cursor = last_seq.map(verified_core::batch::next_exclusive_cursor);\n                break;\n            }\n            let tx_id = entry.value();\n            let stored = match state\n                .tx_store\n                .get(&tx_id)\n                .and_then(|e| StoredTx::try_from(e).ok())\n            {\n                Some(value) => value,\n                None => {\n                    continue;\n                }\n            };\n            let key = entry.key().0;\n            let mut seq = [0u8; 8];\n            seq.copy_from_slice(&key[0..8]);\n            items.push(QueueItem {\n                seq: u64::from_be_bytes(seq),\n                tx_id,\n                kind: stored.kind,\n            });\n            last_seq = Some(u64::from_be_bytes(seq));\n        }\n        QueueSnapshot { items, next_cursor }\n    })\n}",
  "span": {
    "start_line": 2552,
    "end_line": 2587
  },
