  "signature": "pub fn block_is_retained(head: u64, retain: u64, block: u64) -> bool",
  "body": "{\n    if block > head {\n        return false;\n    }\n    if retain == 0 || head <= retain {\n        return true;\n    }\n    block > head - retain\n}",
