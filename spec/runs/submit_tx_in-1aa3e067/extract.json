  "signature": "pub fn submit_tx_in(tx_in: TxIn) -> Result<TxId, ChainError>",
  "body": "{\n    match tx_in {\n        TxIn::EthSigned {\n            tx_bytes,\n            caller_principal,\n        } => submit_tx(TxKind::EthSigned, tx_bytes, caller_principal),\n        TxIn::IcSynthetic {\n            caller_principal,\n            canister_id,\n            tx,\n        } => submit_ic_tx_input(caller_principal, canister_id, tx),\n    }\n}",
