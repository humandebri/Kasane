  "signature": "pub fn prune_boundary_safe(previous_present: bool, previous: u64, next_present: bool, next_boundary: u64, head: u64, retain: u64) -> bool",
  "body": "{\n    if !next_present {\n        return true;\n    }\n    if retain == 0 || head <= retain || next_boundary > head - retain {\n        return false;\n    }\n    if previous_present {\n        previous <= next_boundary\n    } else {\n        true\n    }\n}",
