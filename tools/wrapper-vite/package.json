{
  "name": "ic-evm-wrapper-dashboard-vite",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "bindgen": "node ./scripts/generate-bindings.mjs",
    "bindgen:check": "node ./scripts/check-bindings.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx tests/run.ts",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "test:local:preflight": "npm run bindgen:check && npm run lint && npm test && npm run build && npm run juno:functions:build",
    "test:local:smoke": "node scripts/local-smoke.mjs",
    "test:local:wrapper": "node scripts/local-wrapper-smoke.mjs",
    "test:local:wrapper:preflight": "sh scripts/local-wrapper-preflight.sh",
    "juno:emulator:start": "juno emulator start",
    "juno:emulator:stop": "juno emulator stop",
    "juno:functions:build": "juno functions build",
    "juno:hosting:prune": "npx @junobuild/cli@0.14.3 hosting prune",
    "juno:hosting:deploy:prune": "npx @junobuild/cli@0.14.3 hosting deploy --prune"
  },
  "dependencies": {
    "@dfinity/ic-pub-key": "1.0.1",
    "@icp-sdk/core": "^5.0.0",
    "@junobuild/core": "^5.2.2",
    "@noble/hashes": "^1.8.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.539.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.2",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.3.7",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@icp-sdk/bindgen": "^0.2.3",
    "@junobuild/config": "latest",
    "@junobuild/functions": "latest",
    "@junobuild/vite-plugin": "latest",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.0",
    "tailwindcss": "^4.1.12",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vite": "^7.3.2"
  }
}
